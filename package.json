{
  "name": "rtsp-cam-broadcaster",
  "version": "1.0.0",
  "description": "Self-contained Docker image that rebroadcasts an RTSP camera as HLS over a Cloudflare Tunnel.",
  "private": true,
  "type": "module",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "start": "node dist/index.js",
    "dev": "tsx watch src/index.ts",
    "typecheck": "tsc --noEmit",
    "test": "node --import tsx --test test/*.test.ts"
  },
  "dependencies": {
    "@fastify/static": "^8.1.1",
    "fastify": "^5.2.1",
    "hls.js": "^1.5.20",
    "mqtt": "^5.15.2"
  },
  "devDependencies": {
    "@types/node": "^22.13.1",
    "tsx": "^4.19.2",
    "typescript": "^5.7.3"
  }
}
