# ─────────────────────────────────────────────────────────────────────────────
#  Required
# ─────────────────────────────────────────────────────────────────────────────

# Full RTSP URL of the camera. ${VAR} references are expanded from this file,
# so you can keep the credentials in their own variables (below) if you like.
RTSP_URL=rtsp://${FRIGATE_RTSP_USER}:${FRIGATE_RTSP_PASSWORD}@cam.roaming.coia.io:554/cam/realmonitor?channel=1&subtype=0&authbasic=64
FRIGATE_RTSP_USER=changeme
FRIGATE_RTSP_PASSWORD=changeme

# Cloudflare Tunnel token.
# Cloudflare dashboard → Zero Trust → Networks → Tunnels → (your tunnel)
#   → Install connector → copy the token from the `--token ey...` command.
TUNNEL_TOKEN=changeme

# ─────────────────────────────────────────────────────────────────────────────
#  Optional (sensible defaults shown)
# ─────────────────────────────────────────────────────────────────────────────

# Branding on the page.
STREAM_TITLE=Paul's Chickens
STREAM_TAGLINE=Live from the coop 🐔

# Include camera audio (transcoded to AAC). Off by default for max compatibility.
ENABLE_AUDIO=false

# HLS tuning. The playlist window (SEGMENT_TIME × LIST_SIZE) caps how much the
# player can buffer, so a bigger window = smoother playback over a bursty home
# uplink, at the cost of more latency. 2 × 10 = a 20s window is a good balance.
# (Segments split on camera keyframes, so very small SEGMENT_TIME may not shrink
# them further — leave at 2 unless you know your camera's keyframe interval.)
HLS_SEGMENT_TIME=2
HLS_LIST_SIZE=10

# RTSP transport: tcp (reliable, default) or udp (lower latency, can drop).
RTSP_TRANSPORT=tcp

# Cloudflare Tunnel transport. "http2" uses plain outbound TCP 443 and is the
# most firewall-friendly (default). Many home networks block outbound UDP :7844,
# which makes the default "quic" fail to connect. Use "quic" only if your network
# allows that UDP port; "auto" lets cloudflared choose.
TUNNEL_PROTOCOL=http2

# Internal HTTP port (matched by the tunnel's public hostname config).
PORT=8080

# info | debug | warn | error
LOG_LEVEL=info

# ─────────────────────────────────────────────────────────────────────────────
#  Frigate / MQTT (optional) — show snapshots of the last-detected animals
# ─────────────────────────────────────────────────────────────────────────────
# Connect to a Frigate NVR's MQTT broker to display the most recent snapshot of
# each detected animal on the page. Leave MQTT_HOST blank to disable entirely.
# Requires Frigate with snapshots + MQTT enabled.
MQTT_HOST=
MQTT_PORT=1833
MQTT_USERNAME=
MQTT_PASSWORD=
MQTT_TLS=false
MQTT_TOPIC_PREFIX=frigate

# Restrict to one Frigate camera (blank = any camera on the broker).
FRIGATE_CAMERA=camera_name

# Animals to surface, comma-separated (Frigate object labels).
FRIGATE_LABELS=bear,deer,dog,cat,bird,raccoon,fox,squirrel,rabbit

# Advanced: extra ffmpeg input/output flags, space-separated.
# FFMPEG_EXTRA_ARGS=
